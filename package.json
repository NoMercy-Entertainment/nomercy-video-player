{
	"name": "@nomercy-entertainment/nomercy-video-player",
	"type": "module",
	"version": "2.0.0-beta.0",
	"description": "Headless, event-driven HTML5 video player with HLS streaming, subtitle rendering (VTT/ASS/SSA), and a plugin system. No UI — you build your own.",
	"author": {
		"name": "NoMercy Entertainment",
		"email": "info@nomercy.tv",
		"url": "https://nomercy.tv"
	},
	"contributors": [
		"Stoney Eagle <stoney@nomercy.tv>"
	],
	"license": "Apache-2.0",
	"homepage": "https://docs.nomercy.tv/player/video/",
	"bugs": {
		"url": "https://github.com/NoMercy-Entertainment/nomercy-video-player/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NoMercy-Entertainment/nomercy-video-player.git"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"keywords": [
		"video",
		"player",
		"video-player",
		"headless",
		"hls",
		"hls-player",
		"html5",
		"typescript",
		"plugin",
		"streaming",
		"subtitles",
		"ass",
		"ssa",
		"vtt",
		"adaptive",
		"playlist",
		"media",
		"no-ui",
		"event-driven"
	],
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./plugins": {
			"types": "./dist/plugins/index.d.ts",
			"import": "./dist/plugins/index.js"
		},
		"./plugins/cast-sender": {
			"types": "./dist/plugins/cast-sender/index.d.ts",
			"import": "./dist/plugins/cast-sender/index.js"
		},
		"./plugins/desktop-ui": {
			"types": "./dist/plugins/desktop-ui/index.d.ts",
			"import": "./dist/plugins/desktop-ui/index.js"
		},
		"./plugins/drm": {
			"types": "./dist/plugins/drm.d.ts",
			"import": "./dist/plugins/drm.js"
		},
		"./plugins/embed": {
			"types": "./dist/plugins/embed.d.ts",
			"import": "./dist/plugins/embed.js"
		},
		"./plugins/key-handler": {
			"types": "./dist/plugins/key-handler.d.ts",
			"import": "./dist/plugins/key-handler.js"
		},
		"./plugins/live-transcoding": {
			"types": "./dist/plugins/live-transcoding.d.ts",
			"import": "./dist/plugins/live-transcoding.js"
		},
		"./plugins/media-session": {
			"types": "./dist/plugins/media-session.d.ts",
			"import": "./dist/plugins/media-session.js"
		},
		"./plugins/message": {
			"types": "./dist/plugins/message.d.ts",
			"import": "./dist/plugins/message.js"
		},
		"./plugins/octopus": {
			"types": "./dist/plugins/octopus.d.ts",
			"import": "./dist/plugins/octopus.js"
		},
		"./plugins/skipper": {
			"types": "./dist/plugins/skipper.d.ts",
			"import": "./dist/plugins/skipper.js"
		},
		"./plugins/subtitle-overlay": {
			"types": "./dist/plugins/subtitle-overlay/index.d.ts",
			"import": "./dist/plugins/subtitle-overlay/index.js"
		},
		"./plugins/tab-leader": {
			"types": "./dist/plugins/tab-leader.d.ts",
			"import": "./dist/plugins/tab-leader.js"
		},
		"./plugins/touch-zones": {
			"types": "./dist/plugins/touch-zones.d.ts",
			"import": "./dist/plugins/touch-zones.js"
		},
		"./streams/native": {
			"types": "./dist/streams/native.d.ts",
			"import": "./dist/streams/native.js"
		},
		"./streams/hls": {
			"types": "./dist/streams/hls.d.ts",
			"import": "./dist/streams/hls.js"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"CHANGELOG.md",
		"MIGRATION.md",
		"CODE_OF_CONDUCT.md",
		"CONTRIBUTING.md",
		"SECURITY.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint": "eslint --fix .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui --watch",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "npx playwright test",
		"test:e2e:report": "npx playwright show-report reports/playwright",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@nomercy-entertainment/nomercy-player-core": "2.0.0-beta.0"
	},
	"peerDependencies": {
		"hls.js": ">=1.6.0"
	},
	"peerDependenciesMeta": {
		"hls.js": {
			"optional": true
		}
	},
	"devDependencies": {
		"@antfu/eslint-config": "5.3.0",
		"@playwright/test": "^1.59.1",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.2",
		"@vitest/ui": "^4.1.2",
		"eslint": "^9.0.0",
		"eslint-plugin-format": "1.0.1",
		"happy-dom": "^20.8.9",
		"hls.js": "1.6.15",
		"playwright": "^1.59.1",
		"prettier": "3.3.3",
		"prettier-eslint": "^16.4.2",
		"typescript": "5.8.3",
		"vite": "7.3.2",
		"vite-plugin-dts": "4.5.4",
		"vitest": "^4.1.2"
	},
	"overrides": {
		"minimatch": "10.2.4",
		"lodash": "4.18.1",
		"follow-redirects": "1.16.0",
		"uuid": "^11.1.1",
		"fast-uri": "^3.1.2"
	},
	"publishConfig": {
		"access": "public",
		"tag": "beta"
	}
}
